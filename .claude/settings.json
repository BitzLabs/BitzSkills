{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(claude plugin validate:*)",
      "Bash(agy plugin validate:*)",
      "Bash(python3 scripts/bump_version.py:*)",
      "Bash(python3 scripts/release_check.py:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Read(~/.claude/.credentials.json)",
      "Read(.env)",
      "Read(.env.*)"
    ],
    "ask": [
      "Write(~/.claude/skills/**)",
      "Edit(~/.claude/skills/**)",
      "Write(~/.gemini/config/skills/**)",
      "Edit(~/.gemini/config/skills/**)",
      "Bash(git push:*)"
    ]
  },
  "enabledPlugins": {
    "bitz-env@bitzskills": true,
    "bitz-sdd@bitzskills": true,
    "plugin-creator@bitzskills": true,
    "skill-creator@bitzskills": true,
    "bitz-ddd@bitzskills": true,
    "bitz-flow@bitzskills": true
  }
}
