# リポジトリ内の改行コードは LF に統一（Linux / Windows 併用対応）
# text=auto: テキストを自動判定 / eol=lf: 作業ツリーも含め常に LF
* text=auto eol=lf

# バイナリは変換対象外（明示）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.skill binary
*.woff binary
*.woff2 binary

# Windows 専用でCRLFが必須なものだけ例外
*.bat text eol=crlf
*.cmd text eol=crlf
