{
  "name": "BitzSkills Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/BitzSkills,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/BitzSkills",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
 "postCreateCommand": "npm install",
  "remoteUser": "node"
}}
